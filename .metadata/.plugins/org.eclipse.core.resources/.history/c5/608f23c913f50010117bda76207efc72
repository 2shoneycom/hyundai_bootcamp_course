<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
<style>
#button {
  width: 100px;
  height: 50px;
  border-radius: 10px;
  background: green;
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
}

button {
  display: block;
  margin: 10px;
}
</style>
<script src="jquery-3.7.1.min.js"></script>
<script type="text/javascript">
	$(document).ready(function() {
		// 버튼 클릭시 '새 버튼1', '새 버튼2' 생성되는 이벤트 등록
		$('#button').on('click', function() {
			$(this).after("<button class='newButton'>새 버튼2</button>");
			$(this).after("<button class='newButton'>새 버튼1</button>");
		}); // #button.on('click') 끝
		
		// 새로 생성된 버튼에 대한 동적 이벤트 연결
		$(document).on('click', '.newButton', function() {
			window.open(); // 새창 임의 연결
			$(this).on('mouseenter', () => {$(this).css('background', 'green')});
			$(this).on('mouseleave', () => {$(this).css('background', 'yellow')});
		}); // document.on('click') 끝
	}); // ready() 끝
</script>
</head>
<body>
  <div id='button'>버튼</div>
</body>
</html>
org.eclipse.wst.sse.ui.custom_templates=<?xml version\="1.0" encoding\="UTF-8" standalone\="no"?><templates><template autoinsert\="true" context\="html_new" deleted\="false" description\="" enabled\="true" name\="New HTML(JavaScript) _MLP">&lt;\!DOCTYPE html&gt;\n&lt;html&gt;\n&lt;head&gt;\n  &lt;meta charset\="UTF-8"&gt;\n  &lt;title&gt;Insert title here&lt;/title&gt;\n  &lt;script type\="text/javascript"&gt;\t\n\t\t\n  &lt;/script&gt;\n&lt;/head&gt;\n&lt;body&gt;\n\t\n&lt;/body&gt;\n&lt;/html&gt;</template><template autoinsert\="true" context\="html_new" deleted\="false" description\="my html template with jQuery" enabled\="true" name\="my html template with jQuery">&lt;\!DOCTYPE html&gt;\n&lt;html&gt;\n&lt;head&gt;\n&lt;meta charset\="UTF-8"&gt;\n&lt;title&gt;Insert title here&lt;/title&gt;\n&lt;script src\="jquery-3.7.1.min.js"&gt;&lt;/script&gt;\n&lt;script type\="text/javascript"&gt;\n\n&lt;/script&gt;\n&lt;/head&gt;\n&lt;body&gt;\n\n&lt;/body&gt;\n&lt;/html&gt;</template></templates>

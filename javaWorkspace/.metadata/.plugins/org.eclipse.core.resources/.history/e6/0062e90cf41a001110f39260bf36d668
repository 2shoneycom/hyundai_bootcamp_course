	@Override
	public boolean insert(BooksaleDTO dto) throws Exception {
		Connection con = null;
		PreparedStatement pstmt = null; 
		
		// 1. 구매 내역 등록
		String sql = "INSERT INTO booksale VALUES(?,?,?,?,?)";
		
		con = DBConnect.getConnection();
		pstmt = con.prepareStatement(sql);
		
		pstmt.setString(1, dto.getBsNo());
		pstmt.setString(2,  dto.getBsDate());
		pstmt.setInt(3, dto.getBsQty());
		pstmt.setString(4, dto.getClientNo());
		pstmt.setString(5, dto.getBookNo());
		
		int result1 = pstmt.executeUpdate();
		
		// 2. 구매한 도서 book 테이블에서 수량 감소
		// 2. 도서 재고 감소 (기존 재고 - 주문 수량)
        String sql2 = "UPDATE book SET bookStock = bookStock - ? WHERE bookNo = ?";
        pstmt = con.prepareStatement(sql2); // pstmt 재사용
        pstmt.setInt(1, dto.getBsQty());
        pstmt.setString(2, dto.getBookNo());
        int result2 = pstmt.executeUpdate();
		
		if (result1 > 0 && result2 > 0) {
			return true;
		} else {
			return false;
		}
	}


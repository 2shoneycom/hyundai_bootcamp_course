<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="com.spring_mvc.mybatisEx.model.IBookDAO">
	<resultMap id="bookResult" type="com.spring_mvc.mybatisEx.vo.BookVO">
		<result property="bookNo" column="bookNo" />
		<result property="bookName" column="bookName" />
		<result property="bookAuthor" column="bookAuthor" />
		<result property="bookPrice" column="bookPrice" />
		<result property="bookDate" column="bookDate" />
		<result property="bookStock" column="bookStock" />
		<result property="pubNo" column="pubNo" />
	</resultMap>
	
	<!-- public ArrayList<BookVO> listAllBook() -->
	<select id="listAllBook" resultMap="bookResult">
		SELECT * FROM book ORDER BY bookNo
	</select>
	
	<!-- public void insertBook(BookVO bookVo) -->
	<insert id="insertBook" parameterType="com.spring_mvc.mybatisEx.vo.BookVO">
		INSERT INTO book(bookNo, bookName, bookAuthor, bookPrice, bookDate, bookStock)
		VALUES (#{bookNo}, #{bookName}, #{bookAuthor}, #{bookPrice}, #{bookDate}, #{bookStock})
	</insert>

	<!-- public void updateBook(BookVO bookVo) -->
	<update id="updateBook" parameterType="com.spring_mvc.mybatisEx.vo.BookVO">
		UPDATE book SET bookName=${bookName}, bookAuthor=#{bookAuthor}, bookPrice=#{bookPrice},
						bookDate=${bookDate}, bookStock=#{bookStock}
		WHERE bookNo=#{bookNo}
	</update>

	<!-- public void deleteBook(String bookVo) -->
	<delete id="deleteBook" parameterType="string">
		DELETE FROM book WHERE bookNo=${bookNo}  
	</delete>

	<!-- public BookVO detailViewBook(String bookVo) -->
	<select id="detailViewBook" parameterType="string" resultMap="bookResult">
		SELECT * FROM book WHERE bookNo=#{bookNo}
	</select>
	
</mapper>
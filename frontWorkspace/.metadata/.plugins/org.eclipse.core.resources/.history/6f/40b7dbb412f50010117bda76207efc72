<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
<style>
#button {
  width: 100px;
  height: 50px;
  border-radius: 10px;
  background: green;
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
}
</style>
<script src="jquery-3.7.1.min.js"></script>
<script type="text/javascript">
	$(document).ready(function() {
		$('#button').on('click', function() {
			$(this).append("<button class='newButton'>새 버튼1</button>);
		}); // #button.on('click') 끝
		
	}); // ready() 끝
</script>
</head>
<body>
  <div id='button'>버튼</div>
</body>
</html>
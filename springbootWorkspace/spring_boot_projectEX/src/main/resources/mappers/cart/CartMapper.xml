<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spring_boot.projectEx.model.ICartDAO">
	<!-- int checkPrdInCart(HashMap<String, Object> map) -->
	<select id="checkPrdInCart" parameterType="hashmap" resultType="int">
		SELECT COUNT(*) FROM cart WHERE prdNo=#{prdNo} AND memId=#{memId}
	</select>
	
	<!-- void insertCart(CartDTO dto) cartNo는 자동 증가값
		특정 회원이 선택한 상품이 테이블 없는 경우
	-->
	<insert id="insertCart" parameterType="com.spring_boot.projectEx.dto.CartDTO">
		INSERT INTO cart(memId, prdNo, cartQty)
		VALUES (#{memId}, #{prdNo}, #{cartQty})
	</insert>
	
	<!-- 특정 회원이 선택한 상품이 테이블에 있는 경우 
		void updateQtyInCart(CartDTO dto)
		SET cartQty = cartQty + #{cartQty} : 기존 qty값을 select 해서 반환되는 결과과 dto 필드값을 더하게 됨
	-->
	<update id="updateQtyInCart" parameterType="com.spring_boot.projectEx.dto.CartDTO">
		UPDATE cart 
		SET cartQty = cartQty + #{cartQty} 
		WHERE memId=#{memId} AND prdNo=#{prdNo}
	</update>
	
	<!-- ArrayList<CartDTO> cartList(String memId) 
		view에 표현하기 위해 필요한 정보가 cart, product 두 테이블에 존재함 -> join 필요
	-->
	<select id="cartList" parameterType="string" resultType="com.spring_boot.projectEx.dto.CartDTO">
		SELECT C.cartNo, P.prdNo, P.prdImg, P.prdName, P.prdPrice, C.cartQty, C.memId
		FROM product P, cart C
		WHERE P.prdNo=C.prdNo AND C.memId=#{memId} 
		ORDER BY C.cartNo
	</select>	
	
	<!-- void deleteCart(String cartNo) -->
	<delete id="deleteCart" parameterType="string">
		DELETE FROM cart
		WHERE cartNo=#{cartNo}
	</delete>
	
	<!-- void updateCart(HashMap<String, Integer> map) -->
	<update id="updateCart" parameterType="hashmap">
		UPDATE cart
		SET cartQty=#{cartQty}
		WHERE cartNo=#{cartNo}
	</update>
</mapper>